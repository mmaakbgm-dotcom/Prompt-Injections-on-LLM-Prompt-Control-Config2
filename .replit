modules = ["nodejs-20", "python-3.11"]
[agent]
expertMode = true
integrations = ["python_openai_ai_integrations:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Clinic App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "DeepTeam Run"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Eval Variability"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Eval MultiTurn"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Eval Manual Bypass"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Scope Override Run"

[[workflows.workflow]]
name = "Clinic App"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python clinic.py"

[[workflows.workflow]]
name = "DeepTeam Run"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && DEEPTEAM_BATCH_SIZE=8 python run_deepteam.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Eval Variability"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python eval_variability.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Eval MultiTurn"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python eval_multiturn_variability.py"

[[workflows.workflow]]
name = "Eval Manual Bypass"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python eval_phase2_scope_bypass_3_2.py -n 30"

[[workflows.workflow]]
name = "Scope Override Run"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && python run_scope_only.py"

[nix]
channel = "stable-25_05"
packages = ["lsof", "mailutils"]

[[ports]]
localPort = 15500
externalPort = 80
