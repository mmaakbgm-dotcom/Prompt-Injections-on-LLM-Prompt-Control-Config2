# Environment Variables — HealthFirst Clinic (Layer 3.2)
#
# Copy this file to .env and fill in your values.
# The .env file is excluded from version control (.gitignore).
#
# On Replit: these are set automatically via the OpenAI integration.
# Locally: set these in your shell or a .env file.

# OpenAI API credentials
# Used by clinic_3_2.py (Stage 1 and Stage 2 LLM calls)
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key_here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# DeepTeam reads standard OpenAI variable names.
# run_deepteam.py copies AI_INTEGRATIONS_OPENAI_API_KEY → OPENAI_API_KEY automatically.
# If running locally (not on Replit), you may set these directly instead:
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
